<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BorrowHub" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_crimson</item>
        <item name="colorPrimaryVariant">@color/primary_crimson_dark</item>
        <item name="colorOnPrimary">@color/gray_50</item>

        <item name="colorSecondary">@color/gray_500</item>
        <item name="colorSecondaryVariant">@color/gray_700</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <item name="colorSurface">@color/gray_50</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:colorBackground">@color/gray_50</item>
        <item name="colorOnBackground">@color/on_background</item>

        <item name="android:statusBarColor">@color/primary_crimson_dark</item>
        <item name="android:navigationBarColor">@color/gray_50</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Improved Dialog UI -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>
    </style>

    <style name="ThemeOverlay.App.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="alertDialogStyle">@style/MaterialAlertDialog.App</item>
    </style>

    <style name="MaterialAlertDialog.App" parent="MaterialAlertDialog.Material3">
        <item name="shapeAppearance">@style/ShapeAppearance.App.Dialog</item>
    </style>

    <style name="ShapeAppearance.App.Dialog" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Theme.BorrowHub" parent="Base.Theme.BorrowHub" />
</resources>
